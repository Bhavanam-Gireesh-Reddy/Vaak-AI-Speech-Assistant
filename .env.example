# ⚠️ IMPORTANT: This is a TEMPLATE file only
# 🔐 DO NOT add real secrets here
# 🔐 NEVER commit this file with real values
# 
# STEPS:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env: Add YOUR REAL secrets
# 3. NEVER push .env to GitHub
# 4. .gitignore will protect .env automatically

# =============================================================================
# API KEYS - Get from these platforms:
# =============================================================================

# Sarvam AI API Key
# Get from: https://sarvam.ai/dashboard/api-keys
SARVAM_API_KEY=your_sarvam_api_key_here_not_real

# Groq LLM API Key (FREE tier: 14,400 requests/day)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here_not_real

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Local Development (Default)
MONGO_URI=mongodb://localhost:27017

# Redis Configuration (For scalable WebSockets)
USE_REDIS=false
REDIS_URI=redis://localhost:6379

# OR MongoDB Atlas (Cloud) - Replace with your actual connection string
# Get from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/database?retryWrites=true
# ⚠️ NEVER put real password in .env.example
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/live_transcription?retryWrites=true

# Database names (defaults are fine)
MONGO_DB=live_transcription
MONGO_COL=sessions
MONGO_COL_USERS=users

# =============================================================================
# SECURITY
# =============================================================================

# JWT Secret Key (minimum 32 characters)
# Generate random key: python -c "import secrets; print(secrets.token_hex(32))"
# ⚠️ Change this in production to a strong random value
SECRET_KEY=change_me_in_production_use_strong_random_32_chars_min

# =============================================================================
# OPTIONAL: Server Configuration
# =============================================================================

# Uncomment and modify as needed
# UVICORN_HOST=0.0.0.0
# UVICORN_PORT=8000
# UVICORN_WORKERS=4

# =============================================================================
# SECURITY NOTES:
# =============================================================================
# 
# ✅ DO: 
#    • Copy .env.example to .env in your local dev
#    • Add your REAL secrets to .env
#    • Keep .env only on your machine
#    • Use environment variables in production
#    • Rotate credentials if exposed
#
# ❌ DON'T:
#    • Commit .env to git
#    • Share .env file via email/Slack
#    • Hardcode secrets in Python files
#    • Use same credentials for dev and prod
#    • Push real API keys to GitHub
#
# For more info: See SECURITY.md
